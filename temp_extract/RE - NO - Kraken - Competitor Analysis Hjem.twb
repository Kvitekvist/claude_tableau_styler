          </manual-sort>
          <manual-sort column="[federated.1syflcc1d3e0ir1gdj2r31bqjqqz].[none:Calculation_4831095828172472320:nk]" direction="ASC">
            <dictionary>
              <bucket>"Hybel/rom i bofellesskap"</bucket>
              <bucket>"Husleie over 14,499"</bucket>
              <bucket>"Husleie 10,500 - 14,499"</bucket>
              <bucket>"Husleie under 10,499"</bucket>
              <bucket>%all%</bucket>
            </dictionary>
