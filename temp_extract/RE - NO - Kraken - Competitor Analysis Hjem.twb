    <worksheet name="Sheet 14">
      <table>
        <view>
          <datasources>
            <datasource caption="RE_NO_HYBEL_ADS (NMP_SALES_PROD.RE_NO_HYBEL_ADS) (KRAKEN)" name="federated.1syflcc1d3e0ir1gdj2r31bqjqqz"/>
          </datasources>
          <datasource-dependencies datasource="federated.1syflcc1d3e0ir1gdj2r31bqjqqz">
            <column caption="Accommodation Type" datatype="string" name="[ACCOMMODATION_TYPE]" role="dimension" semantic-role="" type="nominal"/>
            <column caption="Price Segment &amp; Category" datatype="string" name="[Calculation_4831095828172472320]" role="dimension" type="nominal">
              <calculation class="tableau" formula="IF &#10;    CONTAINS(LOWER([ACCOMMODATION_TYPE]), &quot;bofellesskap&quot;) &#10;    OR CONTAINS(LOWER([ACCOMMODATION_TYPE]), &quot;rom i&quot;)&#10;    OR STARTSWITH(LOWER([ACCOMMODATION_TYPE]), &quot;hybel&quot;)&#10;THEN &quot;Bedsit / Shared Housing&quot;&#10;&#10;ELSEIF [PRICE_NOK] &lt; 10500 THEN &quot;Rent under 10,499 NOK&quot;&#10;&#10;ELSEIF [PRICE_NOK] &gt;= 10500 AND [PRICE_NOK] &lt; 14500 THEN &quot;Rent 10,500 - 14,499&quot;&#10;&#10;ELSEIF [PRICE_NOK] &gt;= 14500 THEN &quot;Rent over 14,499 NOK&quot;&#10;&#10;ELSE &quot;Other/Uncategorized&quot;&#10;END"/>
            </column>
            <column caption="% ON_FINN" datatype="real" name="[Calculation_7002816009136709633]" role="measure" type="quantitative">
              <calculation class="tableau" formula="COUNTD(IF [ON_FINN] = TRUE THEN [ID] END) / COUNTD([ID])"/>
            </column>
            <column datatype="datetime" name="[ETL_RUN_DATE_DAILY]" role="dimension" type="ordinal"/>
            <column aggregation="Sum" datatype="integer" name="[ID]" role="dimension" type="ordinal"/>
            <column datatype="boolean" name="[ON_FINN]" role="dimension" type="nominal"/>
            <column aggregation="Sum" caption="Price Nok" datatype="integer" name="[PRICE_NOK]" role="dimension" type="ordinal"/>
            <column-instance column="[ID]" derivation="CountD" name="[ctd:ID:qk]" pivot="key" type="quantitative"/>
            <column-instance column="[Calculation_4831095828172472320]" derivation="None" name="[none:Calculation_4831095828172472320:nk]" pivot="key" type="nominal"/>
            <column-instance column="[ETL_RUN_DATE_DAILY]" derivation="None" name="[none:ETL_RUN_DATE_DAILY:qk]" pivot="key" type="quantitative"/>
            <column-instance column="[Calculation_7002816009136709633]" derivation="User" name="[usr:Calculation_7002816009136709633:qk]" pivot="key" type="quantitative"/>
          </datasource-dependencies>
          <filter class="categorical" column="[federated.1syflcc1d3e0ir1gdj2r31bqjqqz].[:Measure Names]">
            <groupfilter function="union" user:op="manual">
              <groupfilter function="member" level="[:Measure Names]" member="&quot;[federated.1syflcc1d3e0ir1gdj2r31bqjqqz].[ctd:ID:qk]&quot;"/>
              <groupfilter function="member" level="[:Measure Names]" member="&quot;[federated.1syflcc1d3e0ir1gdj2r31bqjqqz].[usr:Calculation_7002816009136709633:qk]&quot;"/>
            </groupfilter>
          </filter>
          <manual-sort column="[federated.1syflcc1d3e0ir1gdj2r31bqjqqz].[:Measure Names]" direction="ASC">
            <dictionary>
              <bucket>"[federated.1syflcc1d3e0ir1gdj2r31bqjqqz].[ctd:ID:qk]"</bucket>
