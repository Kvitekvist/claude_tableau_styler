        <column caption="Agency Group" datatype="string" name="[Calculation_786722605313654784]" role="dimension" type="nominal">
          <calculation class="tableau" formula="if CONTAINS([AGENCY_NAME],&quot;Krogsveen&quot;) then &quot;Krogsveen&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;EIE &quot;) then &quot;Eie&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Privatmegleren &quot;) then &quot;Privatmegleren&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;PrivatMegleren &quot;) then &quot;Privatmegleren&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Nordvik &quot;) then &quot;Nordvik&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Proaktiv &quot;) then &quot;Proaktiv&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Nylander &quot;) then &quot;Nylander&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Schala &quot;) then &quot;Schala&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;GARANTI&quot;) then &quot;GARANTI&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Garanti&quot;) then &quot;GARANTI&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Sørmegleren &quot;) then &quot;Sørmegleren&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Lokalmegleren&quot;) then &quot;Lokalmegleren&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Meglerhuset&quot;) then &quot;Meglerhuset&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Eiendomsmegler Vest&quot;) then &quot;Eiendomsmegler Vest&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Eiendomsmegler 1&quot;) then &quot;Eiendomsmegler 1&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;EiendomsMegler 1&quot;) then &quot;Eiendomsmegler 1&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Heimdal &quot;) then &quot;Heimdal&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Obos&quot;) then &quot;OBOS&quot;&#13;&#10;elseif CONTAINS([AGENCY_NAME],&quot;Partners &quot;) then &quot;Partners Eiendomsbegling&quot;&#13;&#10;&#13;&#10; else &quot;Other&quot; end"/>
        </column>
        <column datatype="date" name="[ETL_RUN_DATE_DAILY]" role="dimension" type="ordinal"/>
