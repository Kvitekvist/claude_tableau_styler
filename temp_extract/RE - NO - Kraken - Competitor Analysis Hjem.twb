          <filter class="relative-date" column="[federated.1syflcc1d3e0ir1gdj2r31bqjqqz].[none:ETL_RUN_DATE_DAILY:qk]" first-period="-1" include-future="true" include-null="false" last-period="-1" period-type-v2="day"/>
