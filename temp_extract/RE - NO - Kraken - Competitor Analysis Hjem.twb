      <aliases enabled="yes"/>
      <column datatype="string" name="[:Measure Names]" role="dimension" type="nominal">
        <aliases>
          <alias key="&quot;[federated.1syflcc1d3e0ir1gdj2r31bqjqqz].[ctd:ID:qk]&quot;" value="Unique Ads"/>
          <alias key="&quot;[federated.1syflcc1d3e0ir1gdj2r31bqjqqz].[usr:Calculation_7002816009136709633:qk]&quot;" value="% On FINN"/>
        </aliases>
      </column>
      <column caption="Accommodation Type" datatype="string" name="[ACCOMMODATION_TYPE]" role="dimension" semantic-role="" type="nominal"/>
      <column caption="Address" datatype="string" name="[ADDRESS]" role="dimension" type="nominal"/>
      <column caption="Price Segment &amp; Category" datatype="string" name="[Calculation_4831095828172472320]" role="dimension" type="nominal">
        <calculation class="tableau" formula="IF &#10;    CONTAINS(LOWER([ACCOMMODATION_TYPE]), &quot;bofellesskap&quot;) &#10;    OR CONTAINS(LOWER([ACCOMMODATION_TYPE]), &quot;rom i&quot;)&#10;    OR STARTSWITH(LOWER([ACCOMMODATION_TYPE]), &quot;hybel&quot;)&#10;THEN &quot;Bedsit / Shared Housing&quot;&#10;&#10;ELSEIF [PRICE_NOK] &lt; 10500 THEN &quot;Rent under 10,499 NOK&quot;&#10;&#10;ELSEIF [PRICE_NOK] &gt;= 10500 AND [PRICE_NOK] &lt; 14500 THEN &quot;Rent 10,500 - 14,499&quot;&#10;&#10;ELSEIF [PRICE_NOK] &gt;= 14500 THEN &quot;Rent over 14,499 NOK&quot;&#10;&#10;ELSE &quot;Other/Uncategorized&quot;&#10;END"/>
      </column>
      <column caption="Listings" datatype="integer" name="[Calculation_7002816009069236224]" role="measure" type="quantitative">
        <calculation class="tableau" formula="COUNTD(ID)"/>
      </column>
      <column caption="% ON_FINN" datatype="real" name="[Calculation_7002816009136709633]" role="measure" type="quantitative">
        <calculation class="tableau" formula="COUNTD(IF [ON_FINN] = TRUE THEN [ID] END) / COUNTD([ID])"/>
      </column>
      <column caption="FULL_URL" datatype="string" name="[Calculation_7002816009139716098]" role="dimension" type="nominal">
        <calculation class="tableau" formula="'https://hybel.no'+ [URL]"/>
      </column>
      <column caption="Has Video" datatype="boolean" name="[HAS_VIDEO]" role="dimension" type="nominal"/>
      <column aggregation="Sum" datatype="integer" name="[ID]" role="dimension" type="ordinal"/>
      <column caption="Image Url" datatype="string" name="[IMAGE_URL]" role="dimension" type="nominal"/>
      <column caption="Is Premium" datatype="boolean" name="[IS_PREMIUM]" role="dimension" type="nominal"/>
      <column caption="Is Prioritert" datatype="boolean" name="[IS_PRIORITERT]" role="dimension" type="nominal"/>
      <column aggregation="Avg" datatype="real" name="[LATITUDE]" role="measure" semantic-role="[Geographical].[Latitude]" type="quantitative"/>
      <column aggregation="Avg" datatype="real" name="[LONGITUDE]" role="measure" semantic-role="[Geographical].[Longitude]" type="quantitative"/>
      <column datatype="string" name="[MUNICIPALITY]" role="dimension" semantic-role="[County].[Name]" type="nominal"/>
