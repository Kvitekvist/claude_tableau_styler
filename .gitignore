# OS
.DS_Store
Thumbs.db

# Editors / IDE
.vs/
.vscode/
.idea/

# Build & release output
/build/*
!/build/.gitkeep
/releases/*
!/releases/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/
npm-debug.log*

# .NET
bin/
obj/

# Logs
*.log

# Environment / secrets
.env
.env.local

# Tableau workbook files (keep templates only)
/tableau/input/*
!/tableau/input/.gitkeep
/tableau/output/*
!/tableau/output/.gitkeep
/tableau/backups/*
!/tableau/backups/.gitkeep

# Claude Code runtime state
.claude/scheduled_tasks.lock
